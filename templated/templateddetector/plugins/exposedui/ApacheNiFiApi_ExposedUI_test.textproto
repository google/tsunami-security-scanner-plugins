# proto-file: proto/templated_plugin_tests.proto
# proto-message: TemplatedPluginTests

config: {
  tested_plugin: "ApacheNiFiApi_ExposedUI"
}

tests: {
  name: "whenVulnerable_returnsTrue"
  expect_vulnerability: true

  mock_http_server: {
    mock_responses: [
      {
        uri: "/"
        status: 200
        body_content: "... <title>NiFi</title> ..."
      },
      {
        uri: "/nifi-api/access/config"
        status: 200
        body_content: '{"config":{"supportsLogin":false}}'
      }
    ]
  }
}

tests: {
  name: "whenNotApacheNiFi_returnsFalse"
  expect_vulnerability: false

  mock_http_server: {
    mock_responses: [
      {
        uri: "TSUNAMI_MAGIC_ANY_URI"
        status: 200
        body_content: "Hello world"
      }
    ]
  }
}
